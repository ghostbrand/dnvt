generator client {
  provider             = "prisma-client-py"
  interface            = "asyncio"
  recursive_type_depth = 5
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// Enums
enum TipoUsuario {
  ADMIN
  POLICIA
  CIDADAO
}

enum Gravidade {
  LEVE
  MODERADO
  GRAVE
  FATAL
}

enum StatusAcidente {
  REPORTADO
  VALIDADO
  EM_ATENDIMENTO
  ENCERRADO
}

enum OrigemRegistro {
  WEB_POLICIA
  MOBILE_CIDADAO
}

enum ModoCriacaoBO {
  GERADO_SISTEMA
  UPLOAD_MANUAL
}

enum TipoAssistencia {
  AMBULANCIA
  POLICIA
  BOMBEIRO
}

enum StatusAssistencia {
  A_CAMINHO
  NO_LOCAL
  FINALIZADO
}

enum NivelRisco {
  BAIXO
  MEDIO
  ALTO
}

enum TipoAcidente {
  COLISAO_FRONTAL
  COLISAO_TRASEIRA
  COLISAO_LATERAL
  CAPOTAMENTO
  ATROPELAMENTO
  CHOQUE_OBSTACULO
  QUEDA_VEICULO
  OUTRO
}

enum CausaAcidente {
  EXCESSO_VELOCIDADE
  ALCOOL
  DISTRACAO
  FALHA_MECANICA
  MAU_TEMPO
  VIA_DANIFICADA
  ULTRAPASSAGEM_INDEVIDA
  DESRESPEITO_SINALIZACAO
  FADIGA
  OUTRA
}

// Models
model Usuario {
  id                      String       @id @default(auto()) @map("_id") @db.ObjectId
  user_id                 String       @unique
  nome                    String
  email                   String       @unique
  senha                   String?
  telefone                String?
  tipo                    TipoUsuario  @default(CIDADAO)
  bilhete_identidade      String?
  endereco                String?
  zonas_notificacao       String[]     @default([])
  alertas_novos_acidentes Boolean      @default(true)
  alertas_sonoros         Boolean      @default(true)
  alertas_sms             Boolean      @default(false)
  picture                 String?
  google_id               String?
  created_at              DateTime     @default(now())
  updated_at              DateTime     @updatedAt

  acidentes               Acidente[]   @relation("AcidenteCreator")
  boletins                Boletim[]    @relation("BoletimCreator")

  @@map("usuarios")
}

model Acidente {
  id                     String         @id @default(auto()) @map("_id") @db.ObjectId
  acidente_id            String         @unique
  latitude               Float
  longitude              Float
  endereco               String?
  descricao              String
  gravidade              Gravidade      @default(MODERADO)
  tipo_acidente          TipoAcidente   @default(OUTRO)
  causa_principal        CausaAcidente?
  numero_vitimas         Int            @default(0)
  numero_veiculos        Int            @default(1)
  status                 StatusAcidente @default(REPORTADO)
  origem_registro        OrigemRegistro @default(WEB_POLICIA)
  confirmado_oficialmente Boolean       @default(false)
  fotos                  String[]       @default([])
  created_at             DateTime       @default(now())
  updated_at             DateTime       @updatedAt
  created_by             String?
  
  creator                Usuario?       @relation("AcidenteCreator", fields: [created_by], references: [user_id])
  boletins               Boletim[]
  assistencias           Assistencia[]

  @@map("acidentes")
}

model Boletim {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  boletim_id      String        @unique
  acidente_id     String
  numero_processo String
  modo_criacao    ModoCriacaoBO @default(GERADO_SISTEMA)
  observacoes     String?
  vitimas_info    Json[]        @default([])
  veiculos_info   Json[]        @default([])
  testemunhas     Json[]        @default([])
  arquivo_url     String?
  arquivo_data    String?
  arquivo_nome    String?
  created_at      DateTime      @default(now())
  created_by      String?

  acidente        Acidente      @relation(fields: [acidente_id], references: [acidente_id])
  creator         Usuario?      @relation("BoletimCreator", fields: [created_by], references: [user_id])

  @@map("boletins")
}

model Assistencia {
  id              String           @id @default(auto()) @map("_id") @db.ObjectId
  assistencia_id  String           @unique
  acidente_id     String
  tipo            TipoAssistencia
  status          StatusAssistencia @default(A_CAMINHO)
  latitude_atual  Float?
  longitude_atual Float?
  hora_inicio     DateTime         @default(now())
  hora_fim        DateTime?

  acidente        Acidente         @relation(fields: [acidente_id], references: [acidente_id])

  @@map("assistencias")
}

model ZonaCritica {
  id                    String     @id @default(auto()) @map("_id") @db.ObjectId
  zona_id               String     @unique
  latitude_centro       Float
  longitude_centro      Float
  raio_metros           Int        @default(500)
  nome                  String?
  total_acidentes       Int        @default(0)
  acidentes_graves      Int        @default(0)
  causa_mais_frequente  String?
  nivel_risco           NivelRisco @default(BAIXO)
  recomendacao_melhoria String?
  validado              Boolean    @default(false)
  created_at            DateTime   @default(now())

  @@map("zonas_criticas")
}

model Configuracao {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  config_id          String   @unique
  google_maps_api_key String?
  ombala_token       String?
  ombala_sender_name String?
  ombala_sms_balance Int?
  updated_at         DateTime @updatedAt

  @@map("configuracoes")
}

model RotaAlerta {
  id                      String   @id @default(auto()) @map("_id") @db.ObjectId
  id_alerta               String   @unique
  user_id                 String
  latitude_origem         Float
  longitude_origem        Float
  latitude_destino        Float
  longitude_destino       Float
  possui_acidente_na_rota Boolean
  data_consulta           DateTime @default(now())

  @@map("rotas_alertas")
}
