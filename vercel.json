{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build",
        "installCommand": "npm install --legacy-peer-deps"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "backend/server.js"
    },
    {
      "source": "/:path*",
      "destination": "frontend/build/:path*"
    }
  ],
  "env": {
    "NODE_VERSION": "18",
    "DISABLE_ESLINT_PLUGIN": "true"
  }
}
